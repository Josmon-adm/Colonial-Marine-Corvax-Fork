<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'rmc-new-to-job-popup-title'}"
                      SetSize="800 500">
    <BoxContainer Orientation="Vertical" Margin="20">
        <Label Name="TitleLabel"
               StyleClasses="LabelBig"
               HorizontalAlignment="Center"
               Margin="0 0 0 5" />
        <PanelContainer StyleClasses="BackgroundDark" Margin="0 0 0 10" VerticalExpand="True" HorizontalExpand="True">
            <ScrollContainer VerticalExpand="True" HorizontalExpand="True" VScrollEnabled="True" HScrollEnabled="False">
            <BoxContainer Orientation="Vertical" Margin="10" VerticalExpand="True">
                <RichTextLabel Name="NewToJobName" HorizontalAlignment="Center" />
                <Control MinSize="0 5" />
                    <RichTextLabel Name="NewToJobLabel" HorizontalAlignment="Left" Margin="0" />
                <Control MinSize="0 5" />
                <RichTextLabel Name="NewToJobAdditional" HorizontalAlignment="Center" Margin="0 5 0 0" />
            </BoxContainer>
            </ScrollContainer>
        </PanelContainer>

        <PanelContainer StyleClasses="VoteSectionPanel" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" Margin="12 10" VerticalExpand="True">
                <ScrollContainer HScrollEnabled="False"
                                 VScrollEnabled="True"
                                 VerticalExpand="True"
                                 MinSize="0 280">
                    <RichTextLabel Name="NewToJobLabel"
                                   HorizontalAlignment="Left"
                                   HorizontalExpand="True" />
                </ScrollContainer>
            </BoxContainer>
        </PanelContainer>

        <PanelContainer StyleClasses="VoteSectionPanel">
            <BoxContainer Orientation="Vertical" Margin="12 10">
                <RichTextLabel Name="NewToJobAdditional"
                               HorizontalAlignment="Left"
                               HorizontalExpand="True" />
            </BoxContainer>
        </PanelContainer>

        <BoxContainer Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Margin="0 2 0 0">
            <Button Name="NewToJobCloseButton"
                    HorizontalAlignment="Center"
                    MinWidth="180"
                    StyleClasses="CharacterSetupActionButton"
                    TextAlign="Center" />
        </BoxContainer>
    </BoxContainer>
</ccm:DefaultCMWindow>
