    .desc = { ent-RMCBeltHolsterPistolPara.desc }
ent-RMCBeltHolsterPistolParaCustom = заказной пояс подразделения "Драккар"
    .desc = Модифицированный пояс рейдеров спец-подразделения "Драккар" с черной кожаной кобурой с золотой инкрустацией. Состоит из большой сумки и нескольких отделений поменьше, обеспечивающих достаточно места для дополнительных боеприпасов и других необходимых вещей на поле брани — стандартное обмундирование рейдеров "Драккара", высаживающихся в тылы ксеноморфов.
    .suffix = Paramarine, Survivor, Filled, L54 Custom
ent-RMCBeltRoyalMortar = пояс для боеприпасов модели L79
    .desc = Пояс модели L79, сконфигурированная для переноски боеприпасов либо для легкого миномета, либо для многоствольного гранатомета L989A2, а также оружия и магазинов к нему. Изготовлен из специальной ткани, устойчивой к гниению.
    .suffix = PVE, RCM, Filled
ent-RMCBeltRoyalMortarFilled = { ent-RMCBeltRoyalMortar }
    .suffix = PVE, RCM, Filled
    .desc = { ent-RMCBeltRoyalMortar.desc }
ent-RMCBeltHolsterPistolRCML29Filled = кобура вспомогательного вооружения L29
