    .desc = { ent-RMCSatchelSPPWelder.desc }
ent-RMCSatchelPMCMedic = { ent-CMSatchelMarineMedic }
    .desc = Боевой рюкзак медика ЧВК.
ent-RMCSatchelTSEPA = ранец полицейского TSP-4
    .desc = Стандартный ранец MK4 Империи Трёх Солнц.