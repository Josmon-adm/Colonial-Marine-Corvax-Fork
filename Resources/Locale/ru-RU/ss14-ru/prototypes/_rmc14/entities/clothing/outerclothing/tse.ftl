ent-RMCArmorVestTSEPA = бронежилет ПСОПЗ
    .desc = Бронежилет полиции, защищающий от разного рода повреждений.
ent-RMCBaseTSEArmor = { "" }
    .desc = { "" }
ent-RMCArmourM4TSEPA = бронежилет ПСОПЗ образца M4
    .desc = Модицированный вариант бронежилета M4R с дополнительными пластинами для использования в полиции. К нагрудной пластине приварен значок Полицейских Сил Объединённого Правительства Земли.
ent-RMCArmourM4TSEPAChief = бронежилет испектора образца M4
    .desc = Модицированный вариант бронежилета M4R с дополнительными пластинами для использования в полиции. Имеет золотой значок на груди.
ent-RMCJacketParaCombatJacket = полевая куртка подразделения "Драккар"
    .desc = Полевая это, конечно, грубо сказанно. Носить такое в реальных операциях вряд ли кто-то будет, ибо практически не иметь брони - дело спорное, и поэтому многие предпочитают лёгкий бронежилет. Укреплена баллистическими волокнами и защитой от погоды. Как что-то повседневное пойдёт, как реальное полевое обмундирование - нет.
ent-RMCJacketParaCOJacket = служебная куртка Коммандующего Офицера "Драккара"
    .desc = Служебная куртка, которую обычно носят Коммандующие Офицеры когорт спец-подразделения "Драккар". Укреплена лёгкими кевалровыми вставками, что защищают от незначительного урона.
    .suffix = Survivor, Paramarine, CO
ent-RMCJacketParaCOJacketAlt = служебная куртка Коммандующего Офицера "Драккара"
    .desc = Служебная куртка, которую обычно носят Коммандующие Офицеры когорт спец-подразделения "Драккар". Укреплена лёгкими кевалровыми вставками, что защищают от незначительного урона.
    .suffix = Survivor, Paramarine, CO alt
ent-RMCJacketParaCOJacketFilled = { ent-RMCJacketParaCOJacket }
    .suffix = Survivor, Paramarine, Filled, CO
    .desc = { ent-RMCJacketParaCOJacket.desc }
